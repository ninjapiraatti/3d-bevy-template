/target

# Blender backup files
*.blend1
*.blend2

# Raw asset-pack downloads live in assets_src/ subfolders (they contain
# FBX/OBJ sources); only the glTF copies under assets/ are committed.
# Top-level .blend sources in assets_src/ stay committed.
/assets_src/*/

# Save files written by the demo game
/saves/

